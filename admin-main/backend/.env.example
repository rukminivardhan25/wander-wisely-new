# PostgreSQL (same DB as partner portal for verification data)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Port for Admin API (default: 3003)
PORT=3003

# Allowed frontend origins (comma-separated) for CORS
CORS_ORIGIN=http://localhost:8082,http://127.0.0.1:8082,http://localhost:8083,http://127.0.0.1:8083

# Optional: Path to uploads folder (verification documents). Default: ../../vendor-hub-main/backend/uploads from backend dir
# UPLOADS_PATH=C:\path\to\vendor-hub-main\backend\uploads

# Optional: Public URL of this API (for document "Open" links). Default: http://localhost:3003
# ADMIN_API_BASE_URL=http://localhost:3003
