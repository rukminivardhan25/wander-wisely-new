# PostgreSQL connection string (from Neon, Railway, or local)
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Optional: DB that has transport data (listings, buses, cars, car_operating_areas, car_bookings). If not set, bus/car search uses DATABASE_URL.
# Use the same URL as vendor-hub DATABASE_URL. Run vendor-hub migrations 026, 028, 031, 032 first (or: cd vendor-hub-main/backend && npx tsx scripts/run-car-schema.ts).
# TRANSPORT_DATABASE_URL=postgresql://user:password@host:5432/vendor_db?sslmode=require

# Secret for signing JWTs (use a long random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Port for the API server (default: 3001)
PORT=3001

# Allowed origin(s) for CORS. Use one or comma-separated (e.g. if frontend runs on 8081)
CORS_ORIGIN=http://localhost:8080,http://localhost:8081

# Plan Trip: Groq (itinerary text). Get key at https://console.groq.com
GROQ_API_KEY=

# Plan Trip: Unsplash (realistic place images). Use your Access Key (not Secret). https://unsplash.com/oauth/applications
UNSPLASH_ACCESS_KEY=
