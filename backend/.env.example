# PostgreSQL connection string (from Neon, Railway, or local)
# Use the SAME DATABASE_URL for main app and vendor-hub so flights, buses, cars, and bookings all use one database.
# Run vendor-hub migrations (and flight schema: npm run db:flight) on this DB.
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Secret for signing JWTs (use a long random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Port for the API server (default: 3001)
PORT=3001

# Allowed origin(s) for CORS. Include admin-main if it runs on another port (e.g. 5173)
CORS_ORIGIN=http://localhost:8080,http://localhost:8081,http://localhost:5173

# Optional: admin-main app can call /api/admin/feedback with this key (X-Admin-Key header) instead of login
ADMIN_API_KEY=

# Plan Trip: Groq (itinerary text). Get key at https://console.groq.com
GROQ_API_KEY=

# Plan Trip: Unsplash (realistic place images). Use your Access Key (not Secret). https://unsplash.com/oauth/applications
UNSPLASH_ACCESS_KEY=

# Nearby Restaurants (and location search): Google Maps Platform. $200/month free credit. Enable Geocoding API + Places API at https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=
