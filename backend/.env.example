# PostgreSQL connection string (from Neon, Railway, or local)
# Use the SAME DATABASE_URL for main app and vendor-hub so flights, buses, cars, and bookings all use one database.
# Run vendor-hub migrations (and flight schema: npm run db:flight) on this DB.
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Secret for signing JWTs (use a long random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Port for the API server (default: 3001)
PORT=3001

# Allowed origin(s) for CORS. Use one or comma-separated (e.g. if frontend runs on 8081)
CORS_ORIGIN=http://localhost:8080,http://localhost:8081

# Plan Trip: Groq (itinerary text). Get key at https://console.groq.com
GROQ_API_KEY=

# Plan Trip: Unsplash (realistic place images). Use your Access Key (not Secret). https://unsplash.com/oauth/applications
UNSPLASH_ACCESS_KEY=
