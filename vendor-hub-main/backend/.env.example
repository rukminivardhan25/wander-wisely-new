# PostgreSQL connection string. SINGLE-DB SETUP: Use the EXACT SAME URL as main app backend/.env DATABASE_URL so car bookings created by users appear here.
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Optional: Only if main app uses a separate transport DB. For single-DB setup leave this unset.
# TRANSPORT_DATABASE_URL=

# Secret for signing JWTs (use a long random string in production)
JWT_SECRET=your-vendor-hub-jwt-secret-change-in-production

# Port for the Vendor Hub API (default: 3002)
PORT=3002

# Allowed origin(s) for CORS (Vendor Hub frontend runs on 8081; user app on 8080; admin on 8083)
CORS_ORIGIN=http://localhost:8080,http://localhost:8081,http://localhost:8083

# Optional: Admin API key. When set, GET /api/admin/vendors requires header X-Admin-Key with this value (used by admin dashboard).
# ADMIN_API_KEY=your-admin-secret

# Main (user) app API URL – used to fetch bus bookings for vendor Bookings page (default: http://localhost:3001)
MAIN_APP_API_URL=http://localhost:3001
