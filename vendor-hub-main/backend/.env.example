# PostgreSQL connection string (can use same DB as Wander Wisely or a separate one)
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Secret for signing JWTs (use a long random string in production)
JWT_SECRET=your-vendor-hub-jwt-secret-change-in-production

# Port for the Vendor Hub API (default: 3002)
PORT=3002

# Allowed origin(s) for CORS (Vendor Hub frontend typically runs on 8080)
CORS_ORIGIN=http://localhost:8080
