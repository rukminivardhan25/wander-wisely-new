# PostgreSQL connection string (can use same DB as Wander Wisely or a separate one)
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Secret for signing JWTs (use a long random string in production)
JWT_SECRET=your-vendor-hub-jwt-secret-change-in-production

# Port for the Vendor Hub API (default: 3002)
PORT=3002

# Allowed origin(s) for CORS (Vendor Hub frontend runs on 8081; user app on 8080)
CORS_ORIGIN=http://localhost:8080,http://localhost:8081

# Main (user) app API URL – used to fetch bus bookings for vendor Bookings page (default: http://localhost:3001)
MAIN_APP_API_URL=http://localhost:3001
